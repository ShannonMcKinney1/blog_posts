---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommentSection from "../../components/CommentSection.tsx";
import TableOfContents from "../../components/TableOfContents.astro";
import { supabase } from "../../lib/supabase";

export async function getStaticPaths() {
  const { data: posts } = await supabase
    .from("posts")
    .select(`
      *,
      post_tags (
        tags (
          id,
          name,
          slug
        )
      )
    `)
    .eq("published", true);

  return (posts ?? []).map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const tags = post.post_tags?.map((pt: any) => pt.tags).filter(Boolean) ?? [];

// Extract headers from markdown
const headerRegex = /^(#{1,6})\s+(.+)$/gm;
const headers: Array<{ level: number; text: string; id: string }> = [];
let match;
const headerMap = new Map<string, string>();

while ((match = headerRegex.exec(post.content ?? "")) !== null) {
  const level = match[1].length;
  const text = match[2].trim();
  const id = text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
  
  if (level >= 2 && level <= 3) {
    headers.push({ level, text, id });
    headerMap.set(text, id);
  }
}

// Use marked hook to add IDs to headers during rendering
marked.use({
  renderer: {
    heading({ text, depth }) {
      if (depth >= 2 && depth <= 3) {
        const id = headerMap.get(text) || text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
        return `<h${depth} id="${id}">${text}</h${depth}>\n`;
      }
      return `<h${depth}>${text}</h${depth}>\n`;
    }
  }
});

let htmlContent = marked.parse(post.content ?? "") as string;
---

<BaseLayout pageTitle={post.title} description={post.description}>
  {headers.length > 0 && <TableOfContents content={post.content ?? ""} />}
  <article>
    <div class="bg-background-secondary-300">
      {post.cover_image && (
        <img
          src={post.cover_image}
          alt={post.title}
          class="w-full max-h-[400px] object-cover rounded-lg mb-4"
        />
      )}
      <h1>{post.title}</h1>
      <p><em>{post.description}</em></p>
      <p>Published on {new Date(post.published_at).toLocaleDateString()}</p>
    </div>

    <div set:html={htmlContent} />

    {tags.length > 0 && (
      <div class="tags">
        {tags.map((tag: any) => (
          <p class="tag">
            <a href={`/tags/${tag.slug}`}>{tag.name}</a>
          </p>
        ))}
      </div>
    )}

    <CommentSection client:load slug={`blog/${post.slug}`} />
  </article>
</BaseLayout>
